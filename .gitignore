```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.o
*.obj
*.so
*.dll
*.exe

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
*.egg-info/

# Logs and temporary files
*.log
*.tmp
*.swp

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
coverage/
htmlcov/

# Python specific
*.pyo
*.pyd
.Python
*.sqlite
*.sqlite3

# Cache directories
.mypy_cache/
.pytest_cache/
.hypothesis/
```